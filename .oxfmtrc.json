{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "ignorePatterns": [".github/**", "convex/_generated/**", "src/routeTree.gen.ts"],
    "printWidth": 120,
    "tabWidth": 4,
    "semi": false,
    "sortTailwindcss": {
        "stylesheet": "src/index.css",
        "functions": ["cx", "cva"],
        "attributes": ["class", "className", "classList"]
    },
    "sortPackageJson": {
        "sortScripts": true
    },
    "overrides": [
        {
            "files": ["*.json", "*.jsonc"],
            "options": {
                "tabWidth": 4,
                "trailingComma": "none"
            }
        },
        {
            "files": ["*.yml", "*.yaml"],
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": ["*.md"],
            "options": {
                "printWidth": 100,
                "tabWidth": 2,
                "proseWrap": "always"
            }
        }
    ]
}
