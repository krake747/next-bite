# Deployment used by `npx convex dev`
# Get these from your Convex dashboard after running `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-project-id # team: your-team, project: your-project
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site

# Backend authentication (required for convex/auth.ts)
# Set via: npx convex env set CONVEX_SITE_URL https://your-project.convex.site
CONVEX_SITE_URL=https://your-project.convex.site

# Your local dev server URL
VITE_SITE_URL=http://localhost:5173

# Required Convex environment variables (set via `npx convex env set`):
# Run: npx convex env set BETTER_AUTH_SECRET "$(openssl rand -base64 32)"

# Optional: GitHub OAuth (for social login)
# Get these from https://github.com/settings/developers
# AUTH_GITHUB_ID=your_github_oauth_app_client_id
# AUTH_GITHUB_SECRET=your_github_oauth_app_client_secret

# Google Maps API key (get from https://console.cloud.google.com/)
# Enable Maps JavaScript API in Google Cloud Console
VITE_GOOGLE_MAPS_API_KEY=

# PostHog API key (optional, get from https://app.posthog.com/settings/project-api)
VITE_POSTHOG_KEY=

# Google Tag Manager ID (optional, format: GTM-XXXXXX)
VITE_GTM_ID=