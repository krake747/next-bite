{
    "name": "next-bite",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -b && vite build",
        "convex:deploy": "convex deploy",
        "convex:dev": "convex dev",
        "dev": "vite",
        "fmt": "oxfmt  --no-error-on-unmatched-pattern",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "netlify": "pnpx netlify",
        "preview": "vite preview --port=5173"
    },
    "dependencies": {
        "@convex-dev/better-auth": "^0.12.1",
        "@fontsource-variable/fraunces": "^5.2.9",
        "@fontsource-variable/manrope": "^5.2.8",
        "@formisch/solid": "^0.9.5",
        "@kobalte/core": "^0.13.11",
        "@solid-primitives/pointer": "^0.3.5",
        "@solid-primitives/share": "^2.2.4",
        "@solid-primitives/upload": "^0.1.4",
        "@tailwindcss/vite": "^4.2.4",
        "@tanstack/solid-router": "^1.169.1",
        "better-auth": "~1.6.9",
        "convex": "^1.37.0",
        "cva": "1.0.0-beta.4",
        "lucide-solid": "^1.14.0",
        "solid-google-maps": "^0.0.2",
        "solid-js": "^1.9.12",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.4",
        "valibot": "^1.3.1"
    },
    "devDependencies": {
        "@tanstack/router-plugin": "^1.167.31",
        "@types/google.maps": "^3.64.0",
        "@types/node": "^25.6.0",
        "lint-staged": "^16.4.0",
        "oxfmt": "^0.47.0",
        "oxlint": "^1.62.0",
        "simple-git-hooks": "^2.13.1",
        "typescript": "~6.0.3",
        "vite": "8.0.10",
        "vite-plugin-solid": "^2.11.12"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}": "pnpm fmt"
    },
    "browserslist": {
        "production": [
            "last 2 Chrome versions",
            "last 2 ChromeAndroid versions",
            "last 2 Edge versions",
            "last 2 Firefox versions",
            "last 2 FirefoxAndroid versions",
            "last 2 Safari versions",
            "last 2 iOS versions",
            "not IE 11",
            "not dead"
        ],
        "development": [
            "last 1 Chrome version",
            "last 1 ChromeAndroid version",
            "last 1 Edge version",
            "last 1 Firefox version",
            "last 1 FirefoxAndroid version",
            "last 1 Safari version",
            "last 1 iOS version"
        ]
    },
    "packageManager": "pnpm@10.33.0"
}
