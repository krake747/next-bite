{
    "name": "next-bite",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -b && vite build",
        "convex:deploy": "convex deploy",
        "convex:dev": "convex dev",
        "dev": "vite",
        "fmt": "oxfmt  --no-error-on-unmatched-pattern",
        "fmt:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "netlify": "pnpx netlify",
        "preview": "vite preview --port=5173",
        "sandcastle:build": "sandcastle docker build-image",
        "sandcastle:run": "tsx .sandcastle/main.ts"
    },
    "dependencies": {
        "@convex-dev/better-auth": "^0.12.5",
        "@fontsource-variable/fraunces": "^5.2.9",
        "@fontsource-variable/manrope": "^5.2.8",
        "@formisch/solid": "1.0.0-rc.0",
        "@kobalte/core": "^0.13.12",
        "@solid-primitives/pointer": "^0.3.6",
        "@solid-primitives/share": "^2.2.5",
        "@solid-primitives/upload": "^0.1.5",
        "@tailwindcss/vite": "^4.3.3",
        "@tanstack/solid-router": "^1.170.18",
        "better-auth": "~1.6.23",
        "convex": "^1.42.3",
        "cva": "1.0.0-beta.4",
        "lucide-solid": "^1.25.0",
        "solid-google-maps": "^0.0.2",
        "solid-js": "^1.9.14",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.3",
        "valibot": "^1.4.2"
    },
    "devDependencies": {
        "@ai-hero/sandcastle": "^0.12.0",
        "@tanstack/router-plugin": "^1.168.20",
        "@types/google.maps": "^3.65.2",
        "@types/node": "^26.1.1",
        "lint-staged": "^17.0.8",
        "oxfmt": "^0.59.0",
        "oxlint": "^1.74.0",
        "simple-git-hooks": "^2.13.1",
        "tsx": "^4.23.1",
        "typescript": "~7.0.2",
        "vite": "8.1.5",
        "vite-plugin-solid": "^2.11.12"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}": "pnpm fmt"
    },
    "browserslist": {
        "production": [
            "last 2 Chrome versions",
            "last 2 ChromeAndroid versions",
            "last 2 Edge versions",
            "last 2 Firefox versions",
            "last 2 FirefoxAndroid versions",
            "last 2 Safari versions",
            "last 2 iOS versions",
            "not IE 11",
            "not dead"
        ],
        "development": [
            "last 1 Chrome version",
            "last 1 ChromeAndroid version",
            "last 1 Edge version",
            "last 1 Firefox version",
            "last 1 FirefoxAndroid version",
            "last 1 Safari version",
            "last 1 iOS version"
        ]
    },
    "packageManager": "pnpm@11.13.1"
}
